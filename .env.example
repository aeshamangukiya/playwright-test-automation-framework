# =============================================================================
#  Playwright Test Automation Framework — Environment Configuration
#  Copy this file to `.env` and replace values as needed for your environment.
# =============================================================================

# Active environment: `staging` or `production`
ENVIRONMENT=staging

# -----------------------------------------------------------------------------
# Staging (OrangeHRM Open-Source Demo — safe defaults)
# -----------------------------------------------------------------------------
STAGING_BASE_URL=https://opensource-demo.orangehrmlive.com
STAGING_USER_USERNAME=Admin
STAGING_USER_PASSWORD=admin123
STAGING_ADMIN_USERNAME=Admin
STAGING_ADMIN_PASSWORD=admin123

# -----------------------------------------------------------------------------
# Production (replace with your own instance values)
# -----------------------------------------------------------------------------
PRODUCTION_BASE_URL=
PRODUCTION_USER_USERNAME=
PRODUCTION_USER_PASSWORD=
PRODUCTION_ADMIN_USERNAME=
PRODUCTION_ADMIN_PASSWORD=

# -----------------------------------------------------------------------------
# Optional runtime flags
# -----------------------------------------------------------------------------
# CI=true             # Set by GitHub Actions; switches reporter/headless/etc.
# DEBUG=true          # Enables verbose Logger.debug output
